{
  "name": "pacemaker-video",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.4",
  "scripts": {
    "dev": "next dev",
    "prisma:generate": "prisma generate",
    "build": "npm run prisma:generate && next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest",
    "jira": "node scripts/jira-cli.mjs",
    "prepare": "husky",
    "validate-branch-name": "npx validate-branch-name",
    "typecheck": "tsc --noEmit --module esnext --incremental",
    "lint-staged": "npx lint-staged",
    "precommit-generate": "npm run prisma:generate",
    "precommit-tasks": "npm run precommit-generate && npm run validate-branch-name && npm run typecheck && npm run lint-staged",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1080.0",
    "@aws-sdk/s3-request-presigner": "^3.1080.0",
    "@clerk/backend": "^2.33.5",
    "@clerk/nextjs": "^6.39.5",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@headlessui/react": "^2.2.10",
    "@hookform/resolvers": "^5.4.0",
    "@next/env": "^15.5.20",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-checkbox": "^1.3.7",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-progress": "^1.1.10",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@radix-ui/react-use-controllable-state": "^1.2.3",
    "@supabase/supabase-js": "^2.110.0",
    "@wistia/wistia-player-react": "^0.7.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "embla-carousel-react": "^8.6.0",
    "filepond-plugin-image-preview": "^4.6.12",
    "fractional-indexing": "^4.0.0",
    "lucide-react": "^1.22.0",
    "next": "15.5.20",
    "next-themes": "^0.4.6",
    "pdfjs-dist": "5.7.284",
    "pg": "^8.22.0",
    "react": "^18",
    "react-big-calendar": "^1.20.0",
    "react-day-picker": "^9.13.1",
    "react-dom": "^18",
    "react-filepond": "^7.1.3",
    "react-hook-form": "^7.81.0",
    "react-pdf": "^10.4.0",
    "sonner": "^2.0.7",
    "stripe": "^22.3.0",
    "svix": "^1.96.1",
    "tailwind-merge": "^3.6.0",
    "uuid": "^14.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.1.3",
    "@eslint/eslintrc": "^3.3.5",
    "@next/env": "^15.5.20",
    "@next/eslint-plugin-next": "^15.5.20",
    "@storybook/addon-designs": "^10.0.2",
    "@storybook/addon-docs": "^9.1.13",
    "@storybook/nextjs-vite": "^9.1.19",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.0.1",
    "@types/pg": "^8.11.11",
    "@types/react": "^18",
    "@types/react-big-calendar": "^1.16.3",
    "@types/react-dom": "^18",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.5.2",
    "eslint": "^9.39.2",
    "eslint-config-next": "^15.5.20",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-storybook": "^9.1.15",
    "happy-dom": "^20.10.6",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "postcss": "^8",
    "prettier": "^3.9.4",
    "prisma": "^7.8.0",
    "storybook": "^9.1.19",
    "styled-jsx": "^5.1.6",
    "tailwindcss": "^3.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "validate-branch-name": "^1.3.2",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "@hono/node-server": "1.19.14",
    "@prisma/dev": "0.24.3",
    "effect": "^3.21.0",
    "next": {
      "postcss": "8.5.14"
    },
    "node-polyfill-webpack-plugin": "^4.1.0"
  },
  "lint-staged": {
    "*.js": [
      "prettier --write .",
      "eslint --fix ."
    ],
    "*.{ts,tsx}": [
      "tsc-files --noEmit",
      "prettier --write .",
      "eslint --fix ."
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write ."
    ]
  },
  "validate-branch-name": {
    "pattern": "^(main){1}$|^(chore|hotfix|dependabot)\\/([\\/\\w\\-\\d]+)$|^(\\w+-\\d+)\\/([\\w\\-\\d]+)$|^dependabot-",
    "errorMsg": "Please follow standard branch name, rename branch using: git branch -m <oldname> <newname>"
  }
}
